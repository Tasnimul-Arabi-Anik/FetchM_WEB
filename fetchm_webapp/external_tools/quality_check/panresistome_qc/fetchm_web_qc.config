/*
 * FetchM Web adapter configuration for PanResistome QC.
 *
 * FetchM Web already performs metadata filtering and FASTA download. This
 * config keeps PanResistome in local-sample, QC-only mode while the Flask app
 * supplies --local_samples, selected QC modules, thresholds, and output paths.
 */

params {
    stop_after_qc = true
    qc_filter = true
    sequence_qc_engine = 'python'
    representative_only = false

    run_checkm2 = false
    run_gtdbtk = false
    run_quast = false
    run_ani = false
    run_mash = false

    run_panr2_comprehensive = false
    run_amrfinderplus = false
    run_mobsuite = false
    run_genomad = false
    run_isfinder = false
    run_organism_specific_typing = false
    run_kleborate = false
    run_kaptive = false
    run_ectyper = false
}

process {
    errorStrategy = 'terminate'

    withName: CHECKM2_QC {
        cpus = { params.checkm2_threads ? params.checkm2_threads as int : 16 }
        memory = '64 GB'
    }

    withName: QUAST_QC {
        cpus = { Math.min(params.threads as int, 16) }
        memory = '24 GB'
    }

    withName: ANI_ANALYSIS {
        cpus = { Math.min(params.threads as int, 32) }
        memory = '24 GB'
    }

    withName: MASH_PRESCREEN {
        cpus = { Math.min(params.threads as int, 16) }
        memory = '16 GB'
    }
}
