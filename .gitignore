.DS_Store

# Ignore local development files
local_settings.py

# Ignore shell history
.Rhistory

# FetchM Web runtime data and local state
fetchm_webapp/.env
fetchm_webapp/data
fetchm_webapp/data/

# Generated standardization review/audit outputs. Keep rule CSVs in
# fetchm_webapp/standardization/ and Markdown notes, but do not version bulky
# generated review tables.
fetchm_webapp/standardization/review/**/*.csv
fetchm_webapp/standardization/review/**/*.tsv
fetchm_webapp/standardization/review/**/*.txt
fetchm_webapp/standardization/review/**/*.log
fetchm_webapp/standardization/*.before_*.csv

# FetchM Web local backups / variant scratch files
fetchm_webapp/static/styles.backup.css
fetchm_webapp/static/styles.chatgpt_variant_backup.css
fetchm_webapp/templates/index_dashboard.backup.html
fetchm_webapp/templates/index_dashboard.chatgpt_variant_backup.html

# Legacy tool trees not used by the webapp runtime anymore
fetchM/
fetchm/

# Local image assets outside the webapp source tree
fetchm.png
fetchm_species.png
fetchm_website.png
